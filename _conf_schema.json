{
  "enable_inject": {
    "description": "启用思维链注入",
    "type": "bool",
    "default": true
  },
  "online_prompt": {
    "description": "线上模式 Prompt",
    "type": "string",
    "hint": "聊天场景的思维链。留空使用内置默认",
    "default": ""
  },
  "offline_prompt": {
    "description": "线下模式 Prompt",
    "type": "string",
    "hint": "见面/RP场景的思维链。留空使用内置默认",
    "default": ""
  },
  "default_mode": {
    "description": "默认启动模式 (online / offline)",
    "type": "string",
    "default": "online"
  },
  "max_history": {
    "description": "保留最近多少条思考记录",
    "type": "int",
    "default": 200
  }
}